script = ExtResource("5_cameracontroller")

[node name="PhantomCamera" type="Node3D" parent="CameraRig"]
script = ExtResource("8_phantom")
RotationSmoothing = 8.0
DistanceSmoothing = 5.0
MinDistance = 1.5
MaxDistance = 5.0
InputSensitivity = 0.003
LockOnDistance = 3.0
LockOnTransitionSpeed = 5.0
LockOnAngleThreshold = 15.0

[node name="SpringArm3D" type="SpringArm3D" parent="CameraRig"]
spring_length = 4.0
margin = 0.5
collision_mask = 1

[node name="Camera3D" type="Camera3D" parent="CameraRig/SpringArm3D"]
current = true

[node name="AnimationPlayer" type="AnimationPlayer" parent="."]
root_node = NodePath("..")
anim_library = ExtResource("4_animlib")

[node name="AnimationTree" type="AnimationTree" parent="."]
resource = ExtResource("4_animationtree")

[node name="LeftFootIK" type="SkeletonIK3D" parent="."]
root_bone = &"Root"
tip_bone = &"LeftFoot"
use_magnet = true
magnet = Vector3(0, 1, 0)

[node name="RightFootIK" type="SkeletonIK3D" parent="."]
root_bone = &"Root"
tip_bone = &"RightFoot"
use_magnet = true
magnet = Vector3(0, 1, 0)

[node name="FootIKController" type="Node" parent="."]
script = ExtResource("7_footik")
EnableFootIK = true
RaycastDistance = 1.5
InterpolationSpeed = 10.0
MaxFootAngle = 40.0
IKUpdateInterval = 2

[node name="AttackFeedback" type="Node3D" parent="."]
script = ExtResource("2_attack")

[node name="MovementTrail" type="Node3D" parent="."]
script = ExtResource("3_trail")
