          },
          "code_template": "#define SHADER_TOON_CEL\nshader_type spatial;\nrender_mode unshaded;\n\nuniform vec4 base_color : source_color = vec4(1.0);\nuniform float shadow_threshold = 0.25;\nuniform float shadow_softness = 0.05;\n\nvoid fragment() {\n    float NdotL = dot(NORMAL, LIGHT);\n    float toon = smoothstep(shadow_threshold - shadow_softness, shadow_threshold + shadow_softness, NdotL);\n    ALBEDO = base_color.rgb * (0.7 + 0.3 * toon);\n}"
        },
